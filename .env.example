DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
TOSS_AUTH_STUB_USER_ID=local-dev-user-001

# Pusher Channels (Vercel Marketplace 통합 후 자동 주입)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Upstash Redis (Vercel Marketplace "Upstash for Redis" 통합 후 자동 주입)
# SDK는 Redis.fromEnv()로 KV_REST_API_* 또는 UPSTASH_REDIS_REST_* 양쪽 자동 감지
KV_REST_API_URL=
KV_REST_API_TOKEN=
